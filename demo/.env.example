# Copy the values you need into .env.local (gitignored). See README.md.
APP_ENV=dev
APP_SECRET=ai-chat-demo

# Mattermost notifier DSN — https host, bot/personal access token, default channel id.
MATTERMOST_DSN=mattermost://YOUR_ACCESS_TOKEN@chat.survos.com?channel=YOUR_CHANNEL_ID

# Optional default channel id (overrides the DSN channel when mm:post gets no channel arg).
MM_DEFAULT_CHANNEL=
