# Demo defaults. Real values (token, host, channel) go in .env.local (gitignored).
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=ai-chat-demo

# Mattermost notifier DSN (https only — survos-sites/mattermost is live on Dokku at
# chat.survos.com; create a bot + personal access token, grab a channel id).
#   mattermost://<ACCESS_TOKEN>@<HOST>?channel=<CHANNEL_ID>
MATTERMOST_DSN=mattermost://TOKEN@chat.survos.com?channel=CHANNEL_ID

# Optional: default channel id when none is passed to mm:post (overrides the DSN channel).
MM_DEFAULT_CHANNEL=

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/mattermost-notifier ###
# See https://docs.mattermost.com/developer/bot-accounts.html
# MATTERMOST_DSN=mattermost://ACCESS_TOKEN@HOST/PATH?channel=CHANNEL
###< symfony/mattermost-notifier ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
